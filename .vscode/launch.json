{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Development",
      "request": "launch",
      "type": "dart",
      "args": [
        "--dart-define-from-file=${workspaceFolder}/.env.development"
      ]
    },
    {
      "name": "Production",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "args": [
        "--dart-define-from-file=${workspaceFolder}/.env.production"
      ]
    }
  ]
}
